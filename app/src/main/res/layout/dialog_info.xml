<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rincian"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama:"
        android:textSize="11sp"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tvInfoName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/btnCopyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Salin Nama"
        android:textSize="12sp"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:paddingStart="0dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="14dp"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Format:"
        android:textSize="11sp"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tvInfoFormat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginBottom="14dp"
        android:layout_marginTop="2dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ukuran:"
        android:textSize="11sp"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tvInfoSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginBottom="14dp"
        android:layout_marginTop="2dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resolusi:"
        android:textSize="11sp"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tvInfoResolution"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginBottom="14dp"
        android:layout_marginTop="2dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Codec:"
        android:textSize="11sp"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tvInfoCodec"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginBottom="14dp"
        android:layout_marginTop="2dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Durasi:"
        android:textSize="11sp"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tvInfoDuration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginBottom="14dp"
        android:layout_marginTop="2dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Path:"
        android:textSize="11sp"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tvInfoPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="2dp" />

</LinearLayout>