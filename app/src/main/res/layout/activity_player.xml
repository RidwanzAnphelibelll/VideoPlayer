<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false" />

    <LinearLayout
        android:id="@+id/brightnessBar"
        android:layout_width="8dp"
        android:layout_height="140dp"
        android:orientation="vertical"
        android:layout_gravity="start|center_vertical"
        android:layout_marginStart="24dp"
        android:background="@drawable/bg_level_bar_track"
        android:gravity="bottom"
        android:visibility="gone">

        <View
            android:id="@+id/brightnessFill"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/bg_level_bar_fill" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/volumeBar"
        android:layout_width="8dp"
        android:layout_height="140dp"
        android:orientation="vertical"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_level_bar_track"
        android:gravity="bottom"
        android:visibility="gone">

        <View
            android:id="@+id/volumeFill"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/bg_level_bar_fill" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvGesture"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_gesture"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_player_scrim">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Kembali" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <ImageButton
                android:id="@+id/btnZoom"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_zoom"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Zoom" />

            <ImageButton
                android:id="@+id/btnSpeed"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_speed"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Kecepatan" />

            <ImageButton
                android:id="@+id/btnLock"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_lock_open"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Kunci layar" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">

                <TextView
                    android:id="@+id/tvCurrent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/white"
                    android:textSize="11sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

            </LinearLayout>

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary"
                android:progressBackgroundTint="@color/border"
                android:layout_marginBottom="10dp" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_pause"
                android:background="@drawable/bg_play_btn"
                android:tint="@color/white"
                android:contentDescription="Play Pause" />

        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/lockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvLockHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Layar Terkunci"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnUnlock"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_lock_closed"
                android:background="@drawable/bg_play_btn"
                android:tint="@color/white"
                android:contentDescription="Buka kunci"
                android:visibility="gone"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>